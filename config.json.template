{
  "system": {
    "name": "qd-agents",
    "version": "1.0.0",
    "environment": "development"
  },
  "llm": {
    // 默认 LLM 提供商，对应 providers 中的 key
    "default_provider": "nvidia",
    "default_model": null,
    "providers": {
      "nvidia": {
        "api_key": "",
        "base_url": "https://integrate.api.nvidia.com/v1",
        "models": [],
        // API 模式: "completion" (Chat Completions) | "response" (Responses API)
        "api_mode": "completion",
        "timeout": 120000,
        "max_retries": 3,
        "auto_discover": true
      },
      "xunfei": {
        "api_key": "",
        "base_url": "https://maas-coding-api.cn-huabei-1.xf-yun.com/v2",
        "models": [
          {
            "name": "astron-code-latest",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 92160,
            "maxTokens": 32768
          }
        ],
        "api_mode": "completion",
        "timeout": 120000,
        "max_retries": 3,
        "auto_discover": false
      }
    },
    "tool_threshold": 50
  },
  "embedding": {
    // 嵌入后端选项: "llama_cpp" | "sentence_transformers"
    //   llama_cpp: 本地 GGUF 模型，无需网络，速度快，内存占用低
    //     需配合 model="hf_KimChen_bge-m3-q4_k_m.gguf" + model_path 指向 .gguf 文件
    //   sentence_transformers: HuggingFace 模型，需下载或离线缓存
    //     需配合 model="BAAI/bge-m3" + hf_token/hf_cache_dir/hf_hub_offline
    "backend": "llama_cpp",
    // llama_cpp 时填 GGUF 文件名，sentence_transformers 时填 HuggingFace 模型名
    "model": "hf_KimChen_bge-m3-q4_k_m.gguf",
    // llama_cpp 时指向 .gguf 文件路径；sentence_transformers 时填 "." 即可
    "model_path": ".",
    // 嵌入向量维度，BGE-M3 固定 1024，不要改
    "vec_dim": 1024,
    // HuggingFace token（sentence_transformers 下载模型时需要）
    "hf_token": "",
    // HuggingFace 缓存目录（sentence_transformers 离线模式时需要）
    "hf_cache_dir": "",
    // 是否离线模式（sentence_transformers 不尝试下载，仅用缓存）
    "hf_hub_offline": false
  },
  "tool_registry": {
    "db_path": "data/tools.db",
    "sqlite_vec_enabled": true
  },
  "memory": {
    "db_path": "data/memory.db",
    "top_k": 5,
    "similarity_threshold": 0.7,
    "hybrid_search": true,
    "auto_save": true,
    "max_recall_chars": 2000,
    "max_recall_results": 5
  },
  "execution": {
    "default_timeout": 30000,
    "per_tool_timeout": {},
    "max_attempts": 3,
    "max_iterations": 100,
    "backoff_strategy": "exponential_with_jitter",
    "initial_delay_ms": 1000,
    "max_delay_ms": 30000,
    "circuit_breaker_enabled": true,
    "circuit_breaker_error_rate": 0.5,
    "circuit_breaker_min_requests": 10,
    "circuit_breaker_half_open_timeout": 30000,
    "code_exec_allowed_modules": [
      "math",
      "datetime",
      "json",
      "re",
      "collections",
      "itertools"
    ],
    "code_exec_blocked_builtins": [
      "eval",
      "exec",
      "__import__",
      "open"
    ],
    "code_exec_timeout": 30000
  },
  "prompts": {
    "template_dir": "src/qd_agents/prompts/templates",
    "default_language": "zh-CN",
    "cache_enabled": true,
    "cache_ttl": 3600
  },
  "storage": {
    "data_dir": "data",
    "traces_dir": "data/traces",
    "audit_dir": "data/audit",
    "trace_retention_days": 30,
    "audit_retention_days": 90
  },
  "observability": {
    "log_level": "INFO",
    "log_output": [
      "file"
    ],
    "log_session_dir": ".",
    "log_rotation": "daily",
    "log_retention_days": 30,
    "log_external_api": false,
    "log_immediate_flush": true,
    "tracing_enabled": true,
    "tracing_exporter": "otlp",
    "tracing_endpoint": "",
    "tracing_sample_rate": 1.0,
    "metrics_enabled": true,
    "metrics_exporter": "prometheus",
    "metrics_port": 9090
  }
}