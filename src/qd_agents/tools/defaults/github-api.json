{
  "id": "default.github-api",
  "name": "github-api",
  "description": "GitHub REST API 客户端，用于访问仓库内容、搜索代码等。需要 GITHUB_TOKEN 环境变量或 runtime.json 中的 github 凭证以避免速率限制。",
  "parameters": {
    "type": "object",
    "properties": {
      "endpoint": {
        "type": "string",
        "description": "GitHub API 端点路径，如 /repos/{owner}/{repo}/contents/{path}"
      },
      "method": {
        "type": "string",
        "description": "HTTP 方法，默认 GET",
        "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
        "default": "GET"
      },
      "params": {
        "type": "object",
        "description": "查询参数"
      },
      "body": {
        "type": "object",
        "description": "请求体（JSON）"
      }
    },
    "required": ["endpoint"]
  },
  "execution": {
    "type": "http",
    "base_url": "https://api.github.com",
    "method": "GET",
    "headers": {
      "Accept": "application/vnd.github+json",
      "X-GitHub-Api-Version": "2022-11-28"
    },
    "env": {
      "GITHUB_TOKEN": "GITHUB_TOKEN"
    },
    "auth_type": "bearer",
    "auth_env_key": "GITHUB_TOKEN"
  },
  "scope": "default",
  "metadata": {
    "tags": ["github", "api", "vcs"],
    "category": "web-api"
  }
}
